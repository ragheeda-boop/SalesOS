{
  "name": "salesos",
  "version": "5.0.0",
  "private": true,
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "jest --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "dev:company": "cd apps/company-workspace && next dev",
    "dev:search": "cd apps/search && next dev",
    "build:packages": "tsc -b packages/*/tsconfig.json",
    "storybook": "storybook dev -p 6006",
    "clean": "rm -rf node_modules packages/*/dist apps/*/.next"
  },
  "dependencies": {
    "next": "^15.0",
    "react": "^19.0",
    "react-dom": "^19.0",
    "@radix-ui/react-avatar": "^1.1",
    "@radix-ui/react-dialog": "^1.1",
    "@radix-ui/react-dropdown-menu": "^2.1",
    "@radix-ui/react-select": "^2.1",
    "@radix-ui/react-tabs": "^1.1",
    "@radix-ui/react-toast": "^1.2",
    "@radix-ui/react-tooltip": "^1.1",
    "@tanstack/react-table": "^8.20",
    "@tanstack/react-query": "^5.60",
    "lucide-react": "^0.460",
    "tailwind-merge": "^2.6",
    "clsx": "^2.1",
    "class-variance-authority": "^0.7",
    "axios": "^1.7",
    "zod": "^3.23",
    "react-hook-form": "^7.54",
    "@hookform/resolvers": "^3.9",
    "next-themes": "^0.4",
    "@salesos/ui": "*",
    "@salesos/icons": "*",
    "@salesos/charts": "*",
    "@salesos/forms": "*",
    "@salesos/runtime": "*",
    "@salesos/renderer": "*",
    "@salesos/hooks": "*",
    "@salesos/config": "workspace:*",
    "@salesos/workspace": "*",
    "@salesos/design-language": "*",
    "@salesos/workspace-generator": "*"
  },
  "devDependencies": {
    "@types/node": "^22.0",
    "@types/react": "^19.0",
    "@types/react-dom": "^19.0",
    "typescript": "^5.7",
    "tailwindcss": "^3.4",
    "postcss": "^8.4",
    "autoprefixer": "^10.4",
    "eslint": "^9.0",
    "eslint-config-next": "^15.0",
    "jest": "^29.7",
    "@testing-library/react": "^16.1",
    "@testing-library/jest-dom": "^6.6",
    "@storybook/react": "^8.0"
  }
}
