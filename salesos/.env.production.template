# SalesOS Production Environment Variables
# Copy this file to .env.production on the VPS
#
# Quick start:
#   cp .env.production.template .env.production
#   Then edit all CHANGE_ME values below.
#
# Generate secure passwords:
#   openssl rand -hex 32   (for POSTGRES_PASSWORD, NEO4J_PASSWORD)
#   openssl rand -hex 64   (for JWT_SECRET_KEY)
#
# ─── Required: CHANGE ALL DEFAULT SECRETS ────────────────────
POSTGRES_PASSWORD=CHANGE_ME
NEO4J_PASSWORD=CHANGE_ME
JWT_SECRET_KEY=CHANGE_ME
DOMAIN=salesos.com              # ← change to your real domain

# ─── Database ────────────────────────────────────────────────
POSTGRES_USER=salesos
POSTGRES_DB=salesos

# Used by Alembic migrations (direct to postgres, not via pgbouncer):
DATABASE_URL=postgresql+asyncpg://salesos:${POSTGRES_PASSWORD}@postgres:5432/salesos

# ─── Neo4j ───────────────────────────────────────────────────
NEO4J_USER=neo4j

# ─── Redis ───────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── OpenAI (required for embeddings and copilot) ────────────
OPENAI_API_KEY=sk-CHANGE_ME
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ─── JWT ─────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── Frontend ────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=https://api.${DOMAIN}

# ─── Scraper API Keys (leave empty to use mock scrapers) ─────
BALADY_API_KEY=
TAQEEM_API_KEY=
NAJIZ_API_KEY=
REGA_API_KEY=
NCNP_API_KEY=

# ─── Notion (for data pipeline integration) ──────────────────
NOTION_TOKEN=

# ─── Observability ───────────────────────────────────────────
LOG_LEVEL=INFO
SENTRY_DSN=                     # https://xxx@sentry.io/xxx

# ─── SMTP (email notifications) ──────────────────────────────
SMTP_HOST=                          # e.g. smtp.gmail.com
SMTP_PORT=465
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@salesos.io

# ─── SSO / OAuth ─────────────────────────────────────────────
SSO_GOOGLE_CLIENT_ID=
SSO_GOOGLE_CLIENT_SECRET=
SSO_MICROSOFT_CLIENT_ID=
SSO_MICROSOFT_CLIENT_SECRET=
SSO_GITHUB_CLIENT_ID=
SSO_GITHUB_CLIENT_SECRET=

# ─── Meilisearch ─────────────────────────────────────────────
MEILI_MASTER_KEY=CHANGE_ME          # openssl rand -hex 32
MEILI_URL=http://meilisearch:7700

# ─── Rate Limiting (requests per window) ─────────────────────
RATE_LIMIT_AUTHENTICATED=100
RATE_LIMIT_ANONYMOUS=20
RATE_LIMIT_SEARCH=30

# ─── Kafka (event bus) ──────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# ─── Feature Flags ───────────────────────────────────────────
FEATURE_SEARCH_FUZZY_V2=false
FEATURE_AI_COPILOT=false
FEATURE_CRM_KANBAN=false

# ─── Celery ──────────────────────────────────────────────────
CELERY_TASK_TIME_LIMIT=600
CELERY_TASK_SOFT_TIME_LIMIT=300
CELERY_RESULT_EXPIRES=86400

# ─── LLM Defaults ───────────────────────────────────────────
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=1024
