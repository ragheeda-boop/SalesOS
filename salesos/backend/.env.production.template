# ─── Environment ────────────────────────────────────────────
ENV=production
DEBUG=false
# Generate with: openssl rand -hex 32
SECRET_KEY=<CHANGE_ME: generate with openssl rand -hex 32>
ALLOWED_HOSTS=https://your-domain.com

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=salesos
POSTGRES_PASSWORD=<CHANGE_ME: secure database password>
POSTGRES_DB=salesos
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://salesos:<PASSWORD>@postgres:5432/salesos

# ─── Neo4j ──────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=<CHANGE_ME: secure neo4j password>

# ─── Redis (optional, for caching) ──────────────────────────
#REDIS_URL=redis://redis:6379/0

# ─── Kafka (planned for V4) ─────────────────────────────────
#KAFKA_BOOTSTRAP_SERVERS=kafka:9092
#KAFKA_GROUP_ID=salesos-group
#KAFKA_AUTO_OFFSET_RESET=earliest

# ─── Celery (optional, for background tasks) ─────────────────
#CELERY_BROKER_URL=redis://redis:6379/1
#CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET_KEY=<CHANGE_ME: generate with openssl rand -hex 32>
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=<CHANGE_ME: OpenAI API key from platform.openai.com>
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ─── SMTP / Email ───────────────────────────────────────────
#SMTP_HOST=smtp.example.com
#SMTP_PORT=587
#SMTP_USER=noreply@example.com
#SMTP_PASSWORD=<CHANGE_ME: SMTP password>
#SMTP_FROM_EMAIL=noreply@example.com
#SMTP_FROM_NAME=SalesOS

# ─── SSO / OAuth ────────────────────────────────────────────
#GOOGLE_CLIENT_ID=<CHANGE_ME>
#GOOGLE_CLIENT_SECRET=<CHANGE_ME>
#MICROSOFT_CLIENT_ID=<CHANGE_ME>
#MICROSOFT_CLIENT_SECRET=<CHANGE_ME>

# ─── MeiliSearch ────────────────────────────────────────────
#MEILI_HOST=http://meilisearch:7700
#MEILI_MASTER_KEY=<CHANGE_ME>

# ─── Feature Flags ──────────────────────────────────────────
FEATURE_SEARCH_FUZZY_V2=false
FEATURE_AI_COPILOT=false
FEATURE_CRM_KANBAN=false
DEMO_MODE=false

# ─── Scraper API Keys ───────────────────────────────────────
# Government data source API keys.
# Without valid keys, scrapers will operate in MOCK MODE.
# Get production keys from respective developer portals:
# ─────────────────────────────────────────────────────────────
# Balady (بلدى) — Municipal commercial licenses
# Sign up: https://balady.gov.sa/developers
BALADY_API_KEY=<CHANGE_ME: balady API key>
BALADY_BASE_URL=https://api.balady.gov.sa/v1
# Taqeem (تقييم) — Credit bureau / evaluations
# Sign up: https://taqeem.gov.sa/developers
TAQEEM_API_KEY=<CHANGE_ME: taqeem API key>
TAQEEM_BASE_URL=https://api.taqeem.gov.sa/v1
# REGA (الهيئة العامة للعقار) — Real estate licenses
# Sign up: https://rega.gov.sa/developers
REGA_API_KEY=<CHANGE_ME: rega API key>
REGA_BASE_URL=https://api.rega.gov.sa/v1
# Najiz (ناجز) — Ministry of Justice litigation
# Sign up: https://najiz.gov.sa/developers
NAJIZ_API_KEY=<CHANGE_ME: najiz API key>
NAJIZ_BASE_URL=https://api.najiz.gov.sa/v1
# NCNP (الإعلانات التجارية) — Commercial notifications
# Sign up: https://ncnp.gov.sa/developers
NCNP_API_KEY=<CHANGE_ME: ncnp API key>
NCNP_BASE_URL=https://api.ncnp.gov.sa/v1

# ─── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_AUTH_PER_MINUTE=100
RATE_LIMIT_SEARCH_PER_MINUTE=30
RATE_LIMIT_ANON_PER_MINUTE=20

# ─── Observability ──────────────────────────────────────────
LOG_LEVEL=INFO
SENTRY_DSN=<CHANGE_ME: sentry DSN>
