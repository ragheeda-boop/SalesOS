# SalesOS Staging Environment
# Copy to .env.staging and fill in secrets for pilot deployment
# NEVER commit .env.staging to version control

# Node environment
NODE_ENV=staging

# Database
POSTGRES_USER=salesos
POSTGRES_PASSWORD=CHANGE_ME_STAGING_PASSWORD
POSTGRES_DB=salesos

# Neo4j
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_STAGING_NEO4J
NEO4J_MAX_CONNECTIONS=50
NEO4J_CONNECTION_TIMEOUT=30
NEO4J_MAX_RETRIES=3

# Redis
REDIS_URL=redis://redis:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# API
NEXT_PUBLIC_API_URL=http://localhost:3000
API_URL=http://backend:8000

# JWT
JWT_SECRET=CHANGE_ME_USE_OPENSSL_rand_hex_32

# OpenAI
OPENAI_API_KEY=

# Sentry (optional — set DSN for staging error tracking)
SENTRY_DSN=

# Grafana
GRAFANA_PASSWORD=CHANGE_ME_STAGING_GRAFANA

# Domain (leave as localhost for staging)
DOMAIN=localhost

# Backup (optional staging backups)
BACKUP_RETENTION_DAYS=7
S3_BUCKET=
NOTIFY_WEBHOOK=
