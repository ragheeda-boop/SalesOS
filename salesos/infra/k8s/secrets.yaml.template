# =============================================================================
# SalesOS Kubernetes Secrets — TEMPLATE
# =============================================================================
# Copy this file to secrets.yaml and replace every CHANGE_ME value.
#
# Generate a JWT secret:
#   openssl rand -hex 32
#
# Generate a database password:
#   openssl rand -base64 24
#
# ⚠️  NEVER commit secrets.yaml to version control.
# =============================================================================

apiVersion: v1
kind: Secret
metadata:
  name: salesos-secrets
type: Opaque
stringData:
  database_url: "postgresql+asyncpg://salesos:CHANGE_ME_DB_PASSWORD@postgres:5432/salesos"
  jwt_secret_key: "CHANGE_ME_JWT_SECRET_RUN_openssl_rand_hex_32"
  openai_api_key: "CHANGE_ME_OPENAI_API_KEY"
