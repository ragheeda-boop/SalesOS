{
  "__inputs": [],
  "__requires": [],
  "title": "SalesOS Overview",
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "panels": [
    {
      "title": "HTTP Request Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(salesos_http_requests_total[1m])",
          "legendFormat": "{{method}} {{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "description": "HTTP requests per second by method and path"
    },
    {
      "title": "P50 / P95 / P99 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(salesos_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(salesos_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(salesos_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "description": "HTTP request latency percentiles over 5m windows"
    },
    {
      "title": "Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(salesos_http_requests_total{status=~\"5..\"}[5m]) / rate(salesos_http_requests_total[5m]) * 100",
          "legendFormat": "error rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 20
          }
        }
      },
      "description": "HTTP 5xx error rate as percentage of total requests"
    },
    {
      "title": "DB Query Duration (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(salesos_db_query_duration_seconds_bucket[5m]))",
          "legendFormat": "{{query_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "description": "P95 database query duration by query name"
    },
    {
      "title": "AI Inference Duration (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(salesos_ai_inference_duration_seconds_bucket[5m]))",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "smooth",
            "fillOpacity": 10
          }
        }
      },
      "description": "P95 AI inference duration by model"
    },
    {
      "title": "Service Health",
      "type": "stat",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "up{job=\"salesos-backend\"}",
          "legendFormat": "Backend"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "steps": [
              { "color": "red", "value": 0 },
              { "color": "green", "value": 1 }
            ]
          }
        }
      },
      "description": "Service health status (1=up, 0=down)"
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "salesos_uptime_seconds",
          "legendFormat": "uptime"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green" }
            ]
          }
        }
      },
      "description": "Application uptime in seconds"
    },
    {
      "title": "Pipeline: Records Ingested",
      "type": "stat",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 24 },
      "targets": [{
        "expr": "salesos_pipeline_records_ingested_total",
        "legendFormat": "total"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green" }] }
        }
      }
    },
    {
      "title": "Pipeline: Errors by Stage",
      "type": "bargauge",
      "gridPos": { "h": 4, "w": 8, "x": 8, "y": 24 },
      "targets": [{
        "expr": "salesos_pipeline_errors_total",
        "legendFormat": "{{stage}}"
      }],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "displayName": "{{stage}}"
        }
      }
    },
    {
      "title": "Active Alerts",
      "type": "alertlist",
      "gridPos": { "h": 10, "w": 12, "x": 0, "y": 28 },
      "targets": [],
      "fieldConfig": {
        "defaults": {}
      },
      "description": "List of currently firing alerts"
    }
  ],
  "schemaVersion": 35,
  "refresh": "15s",
  "tags": ["salesos", "monitoring", "overview"],
  "description": "SalesOS system overview dashboard — HTTP, DB, AI, pipeline, and service health"
}
