{
  "__inputs": [],
  "__requires": [],
  "title": "SalesOS API Metrics",
  "uid": "salesos-api-metrics",
  "version": 1,
  "timezone": "browser",
  "editable": true,
  "gnetId": null,
  "graphTooltip": 1,
  "tags": ["salesos", "api", "sla"],
  "description": "API latency, throughput, errors, and SLA compliance",
  "panels": [
    {
      "title": "Request Throughput (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        {
          "expr": "rate(salesos_http_requests_total[1m])",
          "legendFormat": "{{method}} {{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "reqps",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "description": "HTTP requests per second by method and path"
    },
    {
      "title": "Latency Percentiles (P50 / P95 / P99)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        {
          "expr": "histogram_quantile(0.50, rate(salesos_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P50"
        },
        {
          "expr": "histogram_quantile(0.95, rate(salesos_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P95"
        },
        {
          "expr": "histogram_quantile(0.99, rate(salesos_http_request_duration_seconds_bucket[5m]))",
          "legendFormat": "P99"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "description": "HTTP request latency percentiles over 5m window"
    },
    {
      "title": "Error Rate (%)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        {
          "expr": "rate(salesos_http_requests_total{status=~\"5..\"}[5m]) / rate(salesos_http_requests_total[5m]) * 100",
          "legendFormat": "5xx rate"
        },
        {
          "expr": "rate(salesos_http_requests_total{status=~\"4..\"}[5m]) / rate(salesos_http_requests_total[5m]) * 100",
          "legendFormat": "4xx rate"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 5 },
              { "color": "red", "value": 10 }
            ]
          },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 20 }
        }
      },
      "description": "HTTP error rates by class (4xx and 5xx)"
    },
    {
      "title": "Error Total by Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 12, "y": 8 },
      "targets": [
        {
          "expr": "salesos_errors_total{type=\"http_5xx\"}",
          "legendFormat": "5xx"
        },
        {
          "expr": "salesos_errors_total{type=\"http_4xx\"}",
          "legendFormat": "4xx"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "orange", "value": 100 },
              { "color": "red", "value": 500 }
            ]
          }
        }
      }
    },
    {
      "title": "SLA Status",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 18, "y": 8 },
      "targets": [
        {
          "expr": "salesos_app_uptime_seconds",
          "legendFormat": "uptime"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "thresholds" },
          "thresholds": { "steps": [{ "color": "green" }] }
        }
      },
      "description": "Application uptime — SLA depends on 99.9% availability"
    },
    {
      "title": "NBA Engine Processing (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(salesos_nba_processing_duration_seconds_bucket[5m]))",
          "legendFormat": "NBA P95"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "description": "P95 NBA engine processing duration"
    },
    {
      "title": "DB Query Duration (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(salesos_db_query_duration_seconds_bucket[5m]))",
          "legendFormat": "{{query_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "description": "P95 database query duration by query name"
    },
    {
      "title": "AI Inference Duration (P95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, rate(salesos_ai_inference_duration_seconds_bucket[5m]))",
          "legendFormat": "{{model}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth", "fillOpacity": 10 }
        }
      },
      "description": "P95 AI inference duration by model"
    },
    {
      "title": "Request Volume (Top 10 paths)",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 24 },
      "targets": [
        {
          "expr": "topk(10, sum by (method, path) (increase(salesos_http_requests_total[1h])))",
          "legendFormat": "{{method}} {{path}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "unit": "short"
        }
      },
      "description": "Top 10 most-called endpoints in the last hour"
    }
  ],
  "schemaVersion": 35,
  "refresh": "15s"
}
