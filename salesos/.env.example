# SalesOS Environment
# Copy to .env and fill in secrets
# NEVER commit .env to version control

# Database
POSTGRES_USER=salesos
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION
POSTGRES_DB=salesos

# Neo4j
NEO4J_USER=neo4j
NEO4J_PASSWORD=CHANGE_ME_IN_PRODUCTION

# Redis
REDIS_URL=redis://redis:6379/0

# Kafka
KAFKA_BOOTSTRAP_SERVERS=kafka:9092

# API
NEXT_PUBLIC_API_URL=http://localhost:8000
API_URL=http://backend:8000

# JWT
JWT_SECRET=CHANGE_ME_USE_OPENSSL_rand_hex_32

# OpenAI
OPENAI_API_KEY=

# Sentry (optional)
SENTRY_DSN=

# Grafana
GRAFANA_PASSWORD=admin

# Domain (production)
DOMAIN=localhost

# Backup (optional)
BACKUP_RETENTION_DAYS=7
S3_BUCKET=
NOTIFY_WEBHOOK=
