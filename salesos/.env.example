# ─── Environment ────────────────────────────────────────────
ENV=development
DEBUG=true
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALLOWED_HOSTS=localhost,127.0.0.1

# ─── PostgreSQL ─────────────────────────────────────────────
POSTGRES_USER=salesos
POSTGRES_PASSWORD=salesos_dev_password
POSTGRES_DB=salesos
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://salesos:salesos_dev_password@postgres:5432/salesos

# ─── Neo4j ──────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=salesos_neo4j_dev

# ─── Kafka ──────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=kafka:9092
KAFKA_GROUP_ID=salesos-group
KAFKA_AUTO_OFFSET_RESET=earliest

# ─── Redis ──────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── JWT ────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-jwt-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── OpenAI ─────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ─── Frontend ───────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ─── Feature Flags ──────────────────────────────────────────
FEATURE_SEARCH_FUZZY_V2=false
FEATURE_AI_COPILOT=false
FEATURE_CRM_KANBAN=false

# ─── Notion API (for data pipeline scrapers) ─────────────────
NOTION_TOKEN=

# ─── Observability ──────────────────────────────────────────
LOG_LEVEL=DEBUG
SENTRY_DSN=
