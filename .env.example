# ── Environment ──────────────────────────────────────────────
ENV=development
DEBUG=true
LOG_LEVEL=DEBUG

# ── PostgreSQL ───────────────────────────────────────────────
POSTGRES_USER=salesos
POSTGRES_PASSWORD=salesos_dev_password
POSTGRES_DB=salesos
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# ── Neo4j ────────────────────────────────────────────────────
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=salesos_neo4j_dev

# ── Redis ────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ── Meilisearch ──────────────────────────────────────────────
MEILI_URL=http://meilisearch:7700
MEILI_MASTER_KEY=salesos_meili_master_key_dev

# ── JWT / Security ──────────────────────────────────────────
SECRET_KEY=change-me-in-production-min-32-chars
JWT_SECRET_KEY=change-me-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ── AI / ML ──────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-large

# ── Notion ───────────────────────────────────────────────────
NOTION_TOKEN=

# ── Monitoring ───────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ── Frontend ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── Feature Flags ────────────────────────────────────────────
FEATURE_SEARCH_FUZZY_V2=false
FEATURE_AI_COPILOT=false
FEATURE_CRM_KANBAN=false
